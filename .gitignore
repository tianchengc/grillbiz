# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment variables (credentials)
.env
.env.local

# Operating system files
.DS_Store
Thumbs.db
*.tmp

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI Agent Configuration
.agents/
.gents/

# Generated Client Profiles & Business Assets
# (Prevents private business profiles from leaking into the open-source codebase)
grillbiz-profiles/
LEAN_CANVAS.md

# Ignore local test run execution outputs
# (Allows committing test profiles and scripts under tests/ while ignoring generated results)
tests/output/

# Next.js Boilerplate Build Artifacts
**/boilerplate/.next/
**/boilerplate/out/
**/boilerplate/.env.local
**/boilerplate/.env.development.local
**/boilerplate/.env.test.local
**/boilerplate/.env.production.local
**/boilerplate/npm-debug.log*

# Profile Deploy Credentials
grillbiz-profiles/**/*.env.deploy

# Cloudflare Wrangler cache
.wrangler/
